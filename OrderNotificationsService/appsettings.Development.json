{
  "RabbitMq": {
    "HostName": "localhost",
    "ExchangeName": "order-events"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=OrderNotificationsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Monitoring": {
    "FailureRateAlertThresholdPercent": 25,
    "QueueLagAlertThresholdSeconds": 120,
    "MinimumEventsForFailureRateAlert": 20
  }
}